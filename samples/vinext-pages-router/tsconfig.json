{
    "compilerOptions": {
        "outDir": "./dist/",
        "noImplicitAny": true,
        "module": "nodenext",
        "target": "es2020",
        "jsx": "react",
        "skipLibCheck": true,
        "lib": [
            "ES2022",
            "WebWorker"
        ],
        "allowJs": true,
        "strict": true,
        "noImplicitReturns": true,
        "moduleResolution": "nodenext"
    },
    "include": ["src/**/*", "next-shims.d.ts", "vite.config.ts"]
}